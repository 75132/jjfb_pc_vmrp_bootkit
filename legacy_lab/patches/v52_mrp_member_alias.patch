+/* v52: keep the original jjfb.mrp untouched while satisfying the historical
+ * mrc_loader request for cfunction.ext.  The canonical package stores the
+ * actual game EXT as robotol.ext; the 232-byte mrc_loader contains the request
+ * literal at helper+0xCC (file offset 0xD4, entry at +8). */
+static int jjfb_v52_alias_applied;
+static int jjfb_v52_robotol_loaded;
+static uint32_t jjfb_v52_loader_helper;
+static uint32_t jjfb_v52_robotol_helper;
