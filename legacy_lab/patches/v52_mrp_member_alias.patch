+static int jjfb_bridge_env_true(const char *name) {
+    const char *v = getenv(name);
+    if (!v || !*v) return 0;
+    return strcmp(v, "0") != 0 && strcmp(v, "off") != 0 &&
+           strcmp(v, "false") != 0 && strcmp(v, "FALSE") != 0;
+}
+
+static int jjfb_patch_mrc_loader_member_alias(uc_engine *uc, uint32_t helper) {
+    static const char old_name[] = "cfunction.ext";
+    static const char new_name[sizeof(old_name)] = "robotol.ext";
+    const uint32_t expected = helper + 0xCC;
+    uint32_t lo, hi, addr;
+    char probe[sizeof(old_name)];
+
+    if (!uc || helper < CODE_ADDRESS || helper >= END_ADDRESS) return 0;
+
+    /* Fast path proven by the canonical 232-byte mrc_loader.ext audit. */
+    if (expected >= CODE_ADDRESS && expected + sizeof(probe) <= END_ADDRESS &&
+        uc_mem_read(uc, expected, probe, sizeof(probe)) == UC_ERR_OK &&
+        memcmp(probe, old_name, sizeof(old_name)) == 0) {
+        if (uc_mem_write(uc, expected, new_name, sizeof(new_name)) == UC_ERR_OK) {
+            printf("[JJFB_MRP_ALIAS] patched helper=0x%X literal=0x%X "
+                   "request=cfunction.ext target=robotol.ext method=known_offset\n",
+                   helper, expected);
+            fflush(stdout);
+            return 1;
+        }
+    }
+
+    /* Defensive fallback for a loader build with the same literal at a nearby
+     * offset.  Patch only the exact NUL-terminated request nearest this helper. */
+    lo = helper > 0x1000 ? helper - 0x1000 : CODE_ADDRESS;
+    if (lo < CODE_ADDRESS) lo = CODE_ADDRESS;
+    hi = helper + 0x4000;
+    if (hi > END_ADDRESS - sizeof(probe)) hi = END_ADDRESS - sizeof(probe);
+    for (addr = lo; addr <= hi; addr++) {
+        if (uc_mem_read(uc, addr, probe, sizeof(probe)) != UC_ERR_OK) continue;
+        if (memcmp(probe, old_name, sizeof(old_name)) != 0) continue;
+        if (uc_mem_write(uc, addr, new_name, sizeof(new_name)) != UC_ERR_OK) break;
+        printf("[JJFB_MRP_ALIAS] patched helper=0x%X literal=0x%X "
+               "request=cfunction.ext target=robotol.ext method=near_scan\n",
+               helper, addr);
+        fflush(stdout);
+        return 1;
+    }
+
+    printf("[JJFB_MRP_ALIAS] patch_miss helper=0x%X expected=0x%X "
+           "request=cfunction.ext\n", helper, expected);
+    fflush(stdout);
+    return 0;
+}
+
+int jjfb_mrp_alias_applied(void) { return jjfb_v52_alias_applied; }
+int jjfb_robotol_ext_loaded(void) { return jjfb_v52_robotol_loaded; }
+uint32_t jjfb_current_ext_helper(void) { return mr_extHelper_addr; }
+uint32_t jjfb_robotol_ext_helper(void) { return jjfb_v52_robotol_helper; }
